# Copy this file to .env for local development.
# Keep DB_FORCE_SQLITE=1 while you are not using the shared TiDB/MySQL database.

DB_FORCE_SQLITE=1
DB_FALLBACK_SQLITE=1
DEBUG_DB_CONFIG=0

SECRET_KEY=change-this-local-secret
STAFF_DEFAULT_PASSWORD=kyloffee123
LEGACY_CASHIER_OWNER_WINDOW_MINUTES=120

# Optional TiDB/MySQL settings.
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_CA=certs/tidb-ca.pem

# Optional Cloudinary settings for uploaded menu images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kyloffee/menu

# Pilih DATABASE_URL atau variabel TIDB_* di bawah ini.
DATABASE_URL=
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
TIDB_SSL_CA=certs/tidb-ca.pem
TIDB_SSL_VERIFY_CERT=1
TIDB_CONNECT_TIMEOUT=10
AUTO_MIGRATE=0
SCHEMA_RETRY_SECONDS=60

SECRET_KEY=change-this-in-production
SESSION_COOKIE_SECURE=0
STAFF_DEFAULT_PASSWORD=kyloffee123

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kyloffee/menu
